# Canonical public URL for OAuth (must be allowlisted in Supabase …/auth/callback).
# Set for each environment on any host; production must not be localhost unless you only run local.
# NEXT_PUBLIC_SITE_URL (or server-only SITE_URL) is preferred. If unset, origin is inferred from
# X-Forwarded-* headers or the incoming request URL.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Do NOT expose to browser/client bundles.
# Use only for rare privileged server jobs after validating user context.
SUPABASE_SERVICE_ROLE=
GITHUB_TOKEN=

HUGGINGFACE_API_KEY=
HUGGINGFACE_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional override — router root (must end with …/hf-inference; embeddings use …/models/{id}/pipeline/feature-extraction)
# HUGGINGFACE_INFERENCE_BASE=https://router.huggingface.co/hf-inference
# Set to 1 to try batch `inputs: string[]` first (router often rejects it for MiniLM; default uses one string per request)
# HUGGINGFACE_EMBEDDING_TRY_BATCH=0

# Assignment footer — your name & profiles (shown on the landing footer).
NEXT_PUBLIC_AUTHOR_NAME=
NEXT_PUBLIC_AUTHOR_GITHUB_URL=
NEXT_PUBLIC_AUTHOR_LINKEDIN_URL=
